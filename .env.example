# URL backend MBTI khi cài lên AI Portal.
# Khi build (vite/pack), Vite tự đọc file .env và bake URL vào bundle.
# Copy file này thành .env rồi chỉnh URL theo môi trường deploy của bạn.
#
# Trên Portal Tuyen-sinh:
#   VITE_API_BASE=https://ai.neu.edu.vn/tuyen-sinh/api/apps/mbti-career-neu
#
# Trên Portal khác (vd basePath khác hoặc deploy backend tách):
#   VITE_API_BASE=https://your-portal.com/<basepath>/api/apps/mbti-career-neu
#   VITE_API_BASE=https://separate-backend.your-domain.com/mbti-api
#
# Để trống / không set file → frontend dùng window.__WRITE_API_BASE__ (Portal inject runtime).
VITE_AI_BASE=https://mbti-career-neu.vercel.app/

