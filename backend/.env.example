# Cổng backend (mặc định 4000)
PORT=4000

# Chế độ: standalone | embedded (khi cài trên AI Portal)
RUN_MODE=standalone

# Schema PostgreSQL (dùng schema riêng khi cài trên AI Portal)
DB_SCHEMA=mbti_career

# Standalone: URL database hoặc build từ các biến dưới
# DATABASE_URL=postgresql://user:pass@localhost:5432/mbti_career

# Khi cài trên AI Portal: Portal sẽ set PORTAL_DATABASE_URL và dùng DB của Portal
# PORTAL_DATABASE_URL=postgresql://...

# Nếu không có DATABASE_URL thì build từ:
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=123456
POSTGRES_DB=mbti_career

# Tài khoản admin để vào trang quản trị (mặc định admin/admin123)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123

# MinIO — kho chứa tài liệu DOCX MBTI gốc
MINIO_ENDPOINT=
MINIO_PORT=8008
MINIO_ACCESS_KEY=
MINIO_SECRET_KEY=
MINIO_BUCKET=syllabus
MINIO_USE_SSL=false

# AI provider: auto | openai | ollama | none
AI_PROVIDER=auto

# (Tuỳ chọn) External AI JSON endpoint base (vd Vercel).
# Nếu set, backend sẽ gọi: ${EXTERNAL_AI_BASE}/api/ai-consultation?mbtiType=INTJ
# EXTERNAL_AI_BASE=https://<your-vercel-app>
EXTERNAL_AI_BASE=

# OpenAI (tuỳ chọn)
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini

# Ollama (tuỳ chọn) — backend gọi Ollama thay frontend
# OLLAMA_BASE_URL=https://research.neu.edu.vn/ollama
# OLLAMA_MODEL=qwen3:8b
